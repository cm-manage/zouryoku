@page
@model Zouryoku.Pages.SyainSort.SortModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "社員順序並び替え";
}

<form method="post" class="mt-3" id="syainForm">
    <div class="mb-3 d-flex align-items-center">
        <label class="form-label me-2 mb-0 text-nowrap">部署</label>
        <input type="hidden" name="BusyoId" id="BusyoId" value="@(Model.BusyoId?.ToString() ?? "")" />

        <div class="input-group input-group-sm">
            <input type="text" class="form-control" id="BusyoName" readonly value="@Model.BusyoName" />
            <button type="button" class="btn btn-outline-secondary" id="btnSearchBusyo" title="検索">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </div>
    </div>

    <p>社員名をドラッグ＆ドロップして順序を変更できます。ハンドルを掴んで移動してください。</p>

    <ul id="syainList" class="list-group">
        @for (int i = 0; i < Model.Syains.Count; i++)
        {
            var s = Model.Syains[i];
            <li class="list-group-item position-relative bg-light" data-id="@s.Id" draggable="true">
                <input type="hidden" name="Syains[@i].Id" value="@s.Id" />
                <input type="hidden" name="Syains[@i].Jyunjyo" value="@s.Id" class="syain-order" />
                <span class="handle me-2" draggable="true">&#9776;</span>
                <span class="fw-bold">@s.Name</span>
            </li>
        }
    </ul>

    <div class="fixed-bottom bg-white border-top border-dark px-3 py-2 text-end">
        <button type="button" class="btn btn-primary" id="registerBtn"><i class="fa-solid fa-check text-white"></i>登録</button>
    </div>
</form>

@section Scripts {

    <script>
        /* -----------------------
           ヘルパーとグローバル設定
           ----------------------- */

        // 部分ページ要素を都度取得するヘルパー（DOM 準備の問題を回避）
        function getPartialPage() {
            return $('#partial-page-div');
        }

        // 部署IDで部分HTMLを取得する（Promise を返す）
        function loadSyainListAjax(busyoId) {
          return new Promise(resolve => {
            sendGetAjax(
              toUrl('GetSyainList'),
              { busyoId },
              data => {
                  resolve(data);
              },
              false
            );
          });
        }


        // 既存の配列返し用互換関数（必要なら残す）
        function loadSyainList(busyoId) {
            if (!busyoId) return;

            $.get('@Url.Page("/SyainSort", null, new { handler = "GetSyainList" })',
                { busyoId: busyoId })
                .done(function (data) {
                    const list = $("#syainList");
                    list.empty();

                    if (!Array.isArray(data)) {
                        console.error("unexpected syain list response:", data);
                        return;
                    }

                    data.forEach(function (syain, index) {
                        list.append(`
                            <li class="list-group-item position-relative bg-light" data-id="${syain.id}" draggable="true">
                                <input type="hidden" name="Syains[${index}].Id" value="${syain.id}" />
                                <input type="hidden" name="Syains[${index}].Jyunjyo" value="" class="syain-order" />
                                <span class="handle me-2">&#9776;</span>
                                <span class="fw-bold">${syain.name}</span>
                            </li>
                        `);
                    });

                    enableDrag("#syainList");
                })
                .fail(function (xhr, status, err) {
                    console.error("failed to load syain list:", status, err, xhr.responseText);
                });
        }

        /* -----------------------
           ドラッグ有効化
           ----------------------- */
        function enableDrag(listSelector) {
            document.querySelectorAll(listSelector).forEach(list => {
                let dragged = null;

                list.addEventListener("dragstart", e => {
                    const handle = e.target.closest(".handle");
                    if (!handle) {
                        e.preventDefault();
                        return;
                    }
                    dragged = handle.closest("li");
                    e.dataTransfer.effectAllowed = "move";
                });

                list.addEventListener("dragover", e => {
                    e.preventDefault();
                    const target = e.target.closest("li");
                    if (target && dragged && target !== dragged && dragged.parentNode === list && target.parentNode === list) {
                        const rect = target.getBoundingClientRect();
                        const offset = e.clientY - rect.top;
                        const half = rect.height / 2;
                        if (offset < half) list.insertBefore(dragged, target);
                        else list.insertBefore(dragged, target.nextSibling);
                    }
                });

                // ドロップ後の処理（必要なら追加）
                list.addEventListener("drop", e => {
                    e.preventDefault();
                    dragged = null;
                });
            });
        }

        /* -----------------------
           message ハンドラ（グローバルで一度だけ）
           ----------------------- */
          window.addEventListener("message", async function (event) {
          // safeLog を使って console.log で落ちないようにする
          function safeLog() {
            try { if (window.console && typeof console.log === 'function') console.log.apply(console, arguments); } catch(e) {}
          }

          try {
            const data = event.data;
            safeLog('message received', data);
            if (!data || data.type !== "busyoSelected") return;

            const payload = data.payload;
            const busyo = Array.isArray(payload) ? payload[0] : payload;
            const id = busyo && (busyo.id ?? busyo.Id);
            const name = busyo && (busyo.name ?? busyo.Name);

            // 部署名・ID をセット（存在チェック）
            const busyoNameEl = document.getElementById("BusyoName");
            const busyoIdEl = document.getElementById("BusyoId");
            if (busyoNameEl) busyoNameEl.value = name ?? '';
            if (busyoIdEl) busyoIdEl.value = id ?? '';

            safeLog("busyoSelected received:", { id, name });
            if (!id) { safeLog('no id, abort'); return; }

            // 非同期取得を await で扱い、例外を catch する
            try {
              const resp = await loadSyainListAjax(id);
              safeLog('GetSyainList response:', resp);

              // 正規化
              let html = null;
              if (typeof resp === 'string') {
                try { resp = JSON.parse(resp); } catch(e) 
              }

              if (resp && resp.status === '正常' && resp.data) {
                html = resp.data;
              } else if (typeof resp === 'string') {
                html = resp;
              } else if (Array.isArray(resp)) {
                // 互換: 配列が返ってきた場合は従来の描画を行う
                const list = $("#syainList").empty();
                resp.forEach(function (syain, index) {
                  list.append(`
                    <li class="list-group-item position-relative bg-light" data-id="${syain.id}" draggable="true">
                      <input type="hidden" name="Syains[${index}].Id" value="${syain.id}" />
                      <input type="hidden" name="Syains[${index}].Jyunjyo" value="" class="syain-order" />
                      <span class="handle me-2">&#9776;</span>
                      <span class="fw-bold">${syain.name}</span>
                    </li>
                  `);
                });
              } else {
                safeLog("unexpected response from GetSyainList:", resp);
              }

              // 差し替え先があるか確認してから差し替え
              const $partial = $('#partial-page-div');
              if (html && $partial.length) {
                $partial.html(html);
              } else if (!$partial.length) {
                safeLog('#partial-page-div not found');
              }

              // 差し替え後にドラッグを再初期化（#syainList が存在するか確認）
              if ($('#syainList').length) enableDrag("#syainList");
            } catch (err) {
              safeLog("loadSyainListAjax failed:", err);
            }
          } catch (ex) {
            safeLog("message handler error:", ex);
          }
        });



        /* -----------------------
           DOMContentLoaded 初期化
           ----------------------- */
        document.addEventListener("DOMContentLoaded", function () {

            // モーダルを開く
            function openBusyoSearch() {
                const modalId = 'BusyoSearchModal';
                const url = '@Url.Page("/BusyoSentaku/Index", new { mode = "single" })';
                const title = '部署選択';
                showInputModal(modalId, url, null, title, null, 800, 480, 'var(--iframe-header-color)');
            }

            const btn = document.getElementById("btnSearchBusyo");
            if (btn) btn.addEventListener("click", openBusyoSearch);

            // 初期ドラッグ有効化（もし既に要素があるなら）
            enableDrag("#syainList");

            // 登録ボタン
            const registerBtn = document.getElementById('registerBtn');
            if (registerBtn) {
                registerBtn.addEventListener('click', function () {
                    document.querySelectorAll("#syainList > li").forEach((li, index) => {
                        const input = li.querySelector("input.syain-order");
                        if (input) input.value = index + 1;
                    });

                    commonConfirm('登録します。よろしいですか？', null, function () {
                        sendRegisterAjax(toUrl("Register"), $('form#syainForm').serializeArray(), function (data) {
                            registerSuccessSwal('登録しました', null, function () {
                                closeCurrentIziModal();
                            });
                        });
                    });
                });
            }

            // デバッグ用: 部署選択が動かないときの簡易チェック
            console.log('#partial-page-div length =', $('#partial-page-div').length);
            console.log('#syainList length =', $('#syainList').length);
        });
    </script>
}

