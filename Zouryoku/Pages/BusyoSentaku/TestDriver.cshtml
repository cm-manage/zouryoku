@page
@model TestDriverModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "TestDriver";
}

<div>TestDriver</div>
<p>
    <a href="#" class="open-busyo-select" data-busyo-select-multi="false">部署選択（単一）</a>
    <a href="#" class="open-busyo-select" data-busyo-select-multi="true">部署選択（複数）</a>
</p>

<!-- 選択結果表示 -->
<h3>選択された部署:</h3>
<div id="selected-busyo-container" class="mb-3">
</div>

@section InputScripts {
    <script>
        $(function () {

            // -----------------------------
            // 状態管理
            // -----------------------------
            let currentMultiFlag = false;
            // 現在選択されている部署ID（再オープン用）
            let selectedBusyoIds = [];

            // -----------------------------
            // 部署選択画面からのメッセージ受信
            // -----------------------------
            $(window).on("message", function (event) {
                const e = event.originalEvent;

                // セキュリティチェック（オリジン確認）
                if (e.origin !== window.location.origin) return;

                const data = e.data;
                if (!data || data.type !== "busyoSelected") return;

                updateSelectedBusyo(data.payload);
            });

            // -----------------------------
            // 選択結果の描画
            // -----------------------------
            function updateSelectedBusyo(payload) {
                const $container = $('#selected-busyo-container').empty();

                const list = currentMultiFlag ? payload : [payload];
                selectedBusyoIds = list.map(b => b.id);

                list.forEach(busyo => appendBusyoRow($container, busyo));
            }

            // -----------------------------
            // 選択した個々の部署を反映エリアへ追加（動作確認用）
            // -----------------------------
            function appendBusyoRow($container, b) {
                const $row = $('<div>').addClass('busyo-row');
                $('<span>')
                    .text('ID: ' + b.id)
                    .appendTo($row);
                $('<span>')
                    .text(' / 名称: ' + b.name)
                    .appendTo($row);
                $('<span>')
                    .text(' / 順序: ' + b.jyunjyo)
                    .appendTo($row);
                $('<span>')
                    .text(' / 番号: ' + b.code)
                    .appendTo($row);
                $('<span>')
                    .text(' / 親ID: ' + b.oyaId)
                    .appendTo($row);
                $container.append($row);
            }

            // -----------------------------
            // 部署選択モーダル起動
            // -----------------------------
            $('.open-busyo-select').on('click', function (e) {
                e.preventDefault();
                const multi = $(this).data('busyo-select-multi') === true;
                currentMultiFlag = multi;
                openBusyoSelectModal(
                    multi,
                    selectedBusyoIds
                );
            });

        });
    </script>
}
