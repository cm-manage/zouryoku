@page
@using System.Globalization
@model Zouryoku.Pages.BusyoMasterMaintenanceJyunjyoNarabikae.IndexModel
@{
    ViewData["Title"] = "部署順序並び替え";

    // CSSの階層ごとのスタイルを計算するためのパラメータと関数
    const double CssLightnessDecrement = 0.02; // 階層ごとの明度の減少量
    const double CssChromaIncrement = 0.04; // 階層ごとの彩度の増加量
    const double CssBorderWidthBase = 2.0; // 階層0のボーダー幅（px）
    const double CssBorderWidthDecrement = 0.25; // 階層ごとのボーダー幅の減少量（px）
    const double CssBorderWidthMin = 1.0; // ボーダー幅の最小値（px）
    const string CssBorderWidthHoverString = "6px"; // ホバー時のボーダー幅（px）
    string GetLightnessMultiplier(int level) => (1 - level * CssLightnessDecrement).ToString("0.###", CultureInfo.InvariantCulture);
    string GetChromaOffset(int level) => (0 + level * CssChromaIncrement).ToString("0.###", CultureInfo.InvariantCulture);
    string GetBorderWidth(int level) => Math.Max(CssBorderWidthBase - level * CssBorderWidthDecrement, CssBorderWidthMin)
        .ToString("0.###", CultureInfo.InvariantCulture) + "px";
}

<div class="app-screen--entry">
    @* ページ上部のテキスト *@
    <div class="app-area__header mt-3">
        部署名をドラッグ＆ドロップして順序を変更できます。ハンドルを掴んで移動してください。
    </div>

    <form method="post">
        @* 部署ツリー *@
        <div class="app-area__body">
            <ul data-js="sections" class="list-group mt-3">
                @for (int i = 0; i < Model.RootBusyoOrders.Count; i++)
                {
                    @await Html.PartialAsync("_BusyoOrderNode", new IndexModel.BusyoOrderRenderContext(
                        Model.RootBusyoOrders[i], $"busyoOrders[{i}]", CssLevel: 1))
                }
            </ul>
        </div>
    </form>
    <div class="py-3 my-3"></div>
    <!-- フッターエリア -->
    <div class="app-area__footer">
        <hr />
        <div class="text-end p-2">
            <button type="button" class="btn btn-primary app-btn__base" id="register-btn">
                <i class="fa-solid fa-check"></i>登録
            </button>
        </div>
    </div>
</div>

@section InputScripts {
    <script>
        $(function () {
            // [data-js="busyo"] をドラッグで入れ替え可能にする
            // 入れ替え可能なのは同じ階層の要素同士のみ
            // ハンドルは [data-js="handle"]
            // 並び替え後に Jyunjyo の値を更新する
            // ※ jQuery UI Sortable を使用
            $('[data-js="sections"]').sortable({
                cursor: 'move',
                handle: '[data-js="handle"]',
                update: function () {
                    $(this).children('[data-js="busyo"]').children('input[name$=".Jyunjyo"]').each(function (i) {
                        $(this).val(i + 1);
                    });
                }
            });

            // 共通登録 Ajax 処理
            // data: 省略時は form の内容をシリアライズ
            // 戻り値: Promise オブジェクト
            function commonSendRegisterAjax(url, data = $('form').serializeArray()) {
                return new Promise((resolve, reject) => {
                    sendRegisterAjax(url, data, function(result) {
                        switch (result.status) {
                            case responseStatusSuccess: // 成功
                                resolve(result);
                                break;
                            case responseStatusError: // エラー
                                errorMessage(result.message);
                                scrollTo(0, 0);
                                resolve(null);
                                break;
                        }
                    });
                });
            }

            // 登録ボタンイベント
            $('#register-btn').on('click', function () {
                // エラークリア
                errorClear();

                commonConfirm('登録します。よろしいですか？', null, async function() {
                    const result = await commonSendRegisterAjax(toUrl('Register'));

                    if (!result) return;

                    registerSuccessSwal('登録しました', null, function() {
                        closeCurrentIziModal();
                    });
                });
            });
        });
    </script>
}

@section InputStyles {
    <style>
        /* ハンドルのドラッグ可能エリアを拡張する */
        .app-handle {
            margin: -0.5rem -1rem;
            padding: 0.5rem 1rem;
        }

        /* 階層ごとの色分け（ブルー系濃淡） */
        @for (int i = 0; i < IndexModel.CssLevelCount; i++)
        {
            var cssLevel = i + 1; // 1ベースに変換
            var lightnessMultiplier = GetLightnessMultiplier(i);
            var chromaOffset = GetChromaOffset(i);
            var borderWidth = GetBorderWidth(i);
            var hoverLightnessMultiplier = GetLightnessMultiplier(i + 1);
            var hoverChromaOffset = GetChromaOffset(i + 1);
            <text>
            .app-busyo-level-@cssLevel {
                /* フォールバック（oklch未対応ブラウザ向け） */
                background-color: var(--bs-primary-bg-subtle);
                border: @borderWidth solid var(--bs-primary);
                /* モダンブラウザ向け（oklch対応の場合はこちらが優先される） */
                background-color: oklch(from var(--bs-primary-bg-subtle) calc(l * @lightnessMultiplier) calc(c + @chromaOffset) h);
                border: @borderWidth solid oklch(from var(--bs-primary) calc(l * @lightnessMultiplier) c h);
                /* ボーダー幅の変更で中身がずれないように補正 */
                padding-left: calc(var(--bs-list-group-item-padding-x) - @borderWidth);
            }
            /* ホバー時は1階層暗く表示する（:has未対応ブラウザ向けのフォールバック） */
            .app-busyo-level-@cssLevel:hover {
                background-color: var(--bs-primary-bg-subtle);
                border-left: @CssBorderWidthHoverString solid var(--bs-primary);
                /* ボーダー幅の変更で中身がずれないように補正 */
                padding-left: calc(var(--bs-list-group-item-padding-x) - @CssBorderWidthHoverString);
            }
            /* ホバー時は1階層暗く表示する（:has対応ブラウザ向けの詳細な指定） */
            .app-busyo-level-@cssLevel:hover {
                background-color: oklch(from var(--bs-primary-bg-subtle) calc(l * @lightnessMultiplier) calc(c + @chromaOffset) h);
                border-left: @borderWidth solid var(--bs-primary);
                /* ボーダー幅の変更で中身がずれないように補正 */
                padding-left: calc(var(--bs-list-group-item-padding-x) - @borderWidth);
            }
            .app-busyo-level-@cssLevel:hover:not(:has(.list-group-item:hover)) {
                background-color: oklch(from var(--bs-primary-bg-subtle) calc(l * @hoverLightnessMultiplier) calc(c + @hoverChromaOffset) h);
                border-left: @CssBorderWidthHoverString solid oklch(from var(--bs-primary) calc(l * @hoverLightnessMultiplier ) c h);
                /* ボーダー幅の変更で中身がずれないように補正 */
                padding-left: calc(var(--bs-list-group-item-padding-x) - @CssBorderWidthHoverString);
            }
            </text>
        }
    </style>
}
