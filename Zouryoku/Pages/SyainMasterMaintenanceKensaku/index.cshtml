@page
@model Zouryoku.Pages.SyainMasterMaintenanceKensaku.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "社員マスタメンテナンス";
}

@section InputStyles {
    <style>
        /* 検索結果一覧テーブル（画面固有） */
        .app-table__base th.app-table__syain-code {
            width: 10%;
        }

        .app-table__base th.app-table__syain-name {
            width: 20%;
        }

        .app-table__base th.app-table__bumoncyo {
            width: 30%;
        }

        .app-table__base th.app-table__kyusyoku {
            width: 7%;
        }

        .app-table__base th.app-table__kintai-zokusei {
            width: 16%;
        }

        .app-table__base th.app-table__role {
            width: 7%;
        }

        .app-table__base th.app-table__retired {
            width: 7%;
        }

    </style>
}

<partial name="_ZouryokuHeader" model="Model" />

<div class="app-screen--search">
    <form method="get" id="syain-search-form">
        <div class="app-area__search-criteria">
            <div class="row g-3 mt-1">
                <!-- 左カラム -->
                <div class="col-md-6">
                    <div class="row mb-2">
                        <label asp-for="Condition.SyainNo"
                            class="col-2 col-form-label fw-bold text-nowrap app-input__label"></label>
                        <div class="col">
                            <input asp-for="Condition.SyainNo" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label asp-for="Condition.BusyoName"
                             class="col-2 col-form-label fw-bold app-input__label"></label>
                        <div class="col">
                            <div class="input-group">
                                <!-- 表示用：部署名 -->
                                <input asp-for="Condition.BusyoName"
                                       class="form-control bg-light"
                                       readonly />
                                <!-- 検索ボタンのみ -->
                                <button type="button" class="btn btn-primary" id="search-busyo" title="検索">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                </button>
                            </div>
                        </div>
                    </div>


                    <div class="row mb-2">
                        <label asp-for="Condition.Grade"
                             class="col-2 col-form-label fw-bold text-nowrap app-input__label"></label>
                        <div class="col">
                            <input asp-for="Condition.Grade" type="text" class="form-control w-50" />
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label asp-for="Condition.UserRoleId"
                             class="col-2 col-form-label fw-bold text-nowrap app-input__label"></label>
                        <div class="col">
                            <select asp-for="Condition.UserRoleId" asp-items="Model.Condition.UserRoleOptions"
                                class="form-select">
                                <option value="">-- 未選択 --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- 右カラム -->
                <div class="col-md-6">
                    <div class="row mb-2">
                        <label asp-for="Condition.SyainName"
                             class="col-2 col-form-label fw-bold text-nowrap app-input__label"></label>
                        <div class="col">
                            <input asp-for="Condition.SyainName" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label asp-for="Condition.IncludeRetired"
                             class="col-2 col-form-label fw-bold text-nowrap app-input__label"></label>
                        <div class="col d-flex align-items-center">
                            <div class="form-check form-switch m-0">
                                <input asp-for="Condition.IncludeRetired" class="form-check-input" type="checkbox" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label asp-for="Condition.KintaiZokuseiId"
                             class="col-2 col-form-label fw-bold text-nowrap app-input__label"></label>
                        <div class="col">
                            <select 
                                 asp-for="Condition.KintaiZokuseiId" 
                                 asp-items="Model.Condition.KintaiZokuseiOptions"
                                 class="form-select">
                                <option value="">-- 未選択 --</option>
                            </select>

                        </div>
                    </div>

                    <div class="row mb-2">
                        <label asp-for="Condition.Kengen"
                             class="col-2 col-form-label fw-bold text-nowrap app-input__label"></label>
                        <div class="col">
                            <select asp-for="Condition.Kengen"
                                class="form-select" asp-items="Model.Condition.KengenOptions">
                                <option value="">-- 未選択 --</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-auto">
                    <button type="button" class="btn btn-primary app-btn__base" id="search-btn">
                        <i class="fa-solid fa-magnifying-glass"></i>検索
                    </button>
                </div>
            </div>
        </div>

        <div class="app-area__tool-button text-end mb-3">
            <button type="button" class="btn btn-success app-btn__base me-2" id="create-btn">
                <i class="fa fa-plus"></i>新規作成
            </button>
            <button type="button" class="btn btn-secondary app-btn__base" id="sort-btn">
                <i class="fa-solid fa-arrow-up-arrow-down"></i>順序変更
            </button>
        </div>
    </form>

    <!-- 検索結果エリア -->
    <div class="app-area__search-results" id="syain-search-results">
        <partial name="_SyainSearchResults" model="Model" />
    </div>
</div>



@section InputScripts {
    <script>
        $(function() {
            // -----------------------------
            // 初期データ
            // -----------------------------
            const $searchForm = $('#syain-search-form');
            const $partialPage = $('#syain-search-results');

            // -----------------------------
            // モーダル定数
            // -----------------------------
            const modalWidth = 800;
            const modalHeight = 480;
            const headerColor = 'var(--iframe-header-color)';

            // -----------------------------
            // 登録/編集モーダルを開く
            // -----------------------------
            function openInsert(id) {
                const modalId = 'syain-insert-modal';
                const url = '@Url.Page("/SyainMasterMaintenanceTouroku/Index")';
                const title = id ? '社員編集' : '社員マスタ登録';

                showInputModal(modalId, url, id, title, null, modalWidth, modalHeight, headerColor);
            }

            // -----------------------------
            // 並び替えモーダルを開く
            // -----------------------------
            function openSyainSort() {
                const modalId = 'syain-sort-modal';
                const url = '@Url.Page("/SyainMasterMaintenanceJyunjyoNarabikae/Index")';
                const title = '社員順序並び替え';

                showInputModal(modalId, url, null, title, null, modalWidth, modalHeight, headerColor);
            }

            // -----------------------------
            // 部署選択モデル
            // -----------------------------
            function openBusyoSearch() {
                const modalId = 'BusyoSearchModal';
                const url = '@Url.Page("/BusyoSentaku/Index", new { mode = "single" })';
                const title = '部署選択';

                showInputModal(modalId, url, null, title, null, modalWidth, modalHeight, headerColor);
            }

            // -----------------------------
            // 検索
            // -----------------------------
            async function searchSyain(form) {
                return new Promise(resolve => {
                    sendGetAjax(toUrl('Search'), form.serializeArray(), data => resolve(data), false);
                });
            }

            // 検索ボタン押下
            // -----------------------------
            $('#search-btn').on('click', async function () {
                const html = await searchSyain($searchForm);
                $partialPage.html(html);
            });

            // -----------------------------
            // 新規登録ボタン押下
            // -----------------------------
            $('#create-btn').on('click', function () {
                openInsert(null);
            });

            // -----------------------------
            // 順序変更ボタン押下
            // -----------------------------
            $('#sort-btn').on('click', function () {
                openSyainSort();
            });

            // -----------------------------
            //　部署選択ボタン押下
            // -----------------------------
            $('#search-busyo').on('click', function () {
                openBusyoSearch();
            });

            // -----------------------------
            // 部署名リンク押下
            // -----------------------------
            $partialPage.on('click', '.syain-link', function () {
                const id = $(this).data('id');
                openInsert(id);
            });

            // Enter キーで検索
            $searchForm.on('keypress', function(e) {
                if(e.which === 13) {
                   $('#search-btn').click();
                   return false;
                }
            });

            window.addEventListener("message", function (event) {

            const data = event.data;
            if (!data) return;

            if (data.type === "busyoSelected") {
                const busyo = data.payload;
                if (!busyo) return;

                const nameInput = document.querySelector('[name="Condition.BusyoName"]');
                if (nameInput) {
                    nameInput.value = busyo.name ?? busyo.Name ?? "";
                    nameInput.dispatchEvent(new Event('input', { bubbles: true }));
                }

                const idInput = document.querySelector('[name="Condition.BusyoId"]');
                if (idInput) {
                    idInput.value = busyo.id ?? busyo.Id ?? "";
                } else {
                    const form = document.querySelector('form[asp-page-handler="Search"]') || document.querySelector('form');
                    if (form) {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'Condition.BusyoId';
                        hidden.value = busyo.id ?? busyo.Id ?? "";
                        form.appendChild(hidden);
                    }
                }
            }
        });
    });
    </script>
}



