@page
@using Model.Enums
@model Zouryoku.Pages.Explanation.DescriptionModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "勤務状況確認の項目説明";
}
<style>
    .card {
        margin-top: 30px;
    }

    .control-label{
        margin-top: 20px;
        font-size: 20px;
    }
</style>
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="form-group">
                <label class="control-label">勤務状況確認の項目説明</label>
            </div>
            <!-- 年間 セクション -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">年間</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">
                        年間の考え方は、4月を起算とし、翌年の3月までとします。
                    </p>
                </div>
            </div>

            <!-- 残業-45時間 セクション -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">残業-45時間</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">
                        法定休日を含まない残業時間の合計。45時間を超える場合は、拡張申請が必要です。
                    </p>
                </div>
            </div>

            <!-- 残業-100時間 セクション -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">残業-100時間</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">
                        法定休日を含む残業時間の合計。100時間以上はいかなる理由においても禁止です。
                    </p>
                </div>
            </div>

            <!-- 残業-平均最大 セクション -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">残業-平均最大</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">
                        当月含む過去2～6ヶ月の法定休日を含む残業時間の平均の最大です。80時間を超えてはいけません。
                    </p>
                </div>
            </div>

            <!-- 残業-年間累計 セクション -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">残業-年間累計</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">
                        法定休日を含まない残業時間の年間の累計です。720時間を超えてはいけません。
                    </p>
                </div>
            </div>

            <!-- 残業-3ヶ月合計 セクション -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">残業-3ヶ月合計</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">
                        当月を含む連続3ヶ月の残業時間の合計です。60時間を超える場合は、時間外労働原因究明申請が必要です。
                    </p>
                </div>
            </div>

            <!-- 残業-制限超過数 セクション -->
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">残業-制限超過数</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0">
                        代替休暇（代休）と振替休日の違い、付与条件、申請期限等。
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>