@page
@model Zouryoku.Pages.SyainMastaTouroku.InsertModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "社員マスタ登録";
}

<style>
    .no-border {
        border: none;
        background: none;
        width: auto;
    }
</style>

<div class="container bg-light pt-4">
    <div class="d-flex align-items-start justify-content-between mb-3">
        <div class="text-muted me-3">
            履歴対象となる<span class="text-primary fw-bold">*</span>の項目を変更した場合、新たな社員情報が作られます。<br />
            この時、適用開始日が新規データの有効開始日となります。<br />
            再登録（適用開始日と有効開始日が同じ）の場合、履歴は発生せず上書きとなります。<br />
            <span class="text-danger fw-bold">*</span>は必須入力です。<span class="text-primary fw-bold">*</span>は履歴対象です。
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Input.Id" />
        <input type="hidden" id="Kengen" name="Input.Kengen" value="0" />

        <!-- 社員基本情報 -->
        <div class="border border-dark rounded mb-4">
            <div class="bg-primary text-white px-3 py-2 fw-bold fs-5 rounded-top">
                社員基本情報
            </div>

            <div class="px-4 py-3 border-top border-dark rounded-bottom position-relative">
                <div class="position-absolute top-0 end-0 me-4 mt-3 d-flex flex-column align-items-center">
                    <img src="@Url.Page("SyainInsert", "Photo", new { syainId = Model.Input.Id })"
                         alt="写真"
                         class="border rounded mb-2"
                         style="width:96px; height:96px; object-fit:cover;" />

                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btnSetPhoto">写真設定</button>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.Code" class="col-md-3 col-form-label fw-bold small">
                        社員番号<span class="text-danger fw-bold">*</span>
                    </label>
                    <div class="col-md-3">
                        <input asp-for="Input.Code" class="form-control form-control-sm" />
                        <span asp-validation-for="Input.Code" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.Name" class="col-md-3 col-form-label fw-bold small">
                        社員氏名<span class="text-danger fw-bold">*</span><span class="text-primary fw-bold">*</span>
                    </label>
                    <div class="col-md-5">
                        <input asp-for="Input.Name" class="form-control form-control-sm" />
                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.KanaName" class="col-md-3 col-form-label fw-bold small">
                        社員氏名カナ<span class="text-danger fw-bold">*</span>
                    </label>
                    <div class="col-md-5">
                        <input asp-for="Input.KanaName" class="form-control form-control-sm" />
                        <span asp-validation-for="Input.KanaName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.NyuusyaYmd" class="col-md-3 col-form-label fw-bold small">
                        入社年月日<span class="text-danger fw-bold">*</span>
                    </label>
                    <div class="col-md-3">
                        <input asp-for="Input.NyuusyaYmd" type="date" class="form-control form-control-sm" />
                        <span asp-validation-for="Input.NyuusyaYmd" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-md-3 col-form-label fw-bold small">性別<span class="text-danger fw-bold">*</span></label>
                    <div class="col-md-5">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="Input.Seibetsu" value="1" id="male" />
                            <label class="form-check-label" for="male">男</label>
                        </div>
                        <div class="form-check form-check-inline ms-3">
                            <input class="form-check-input" type="radio" asp-for="Input.Seibetsu" value="2" id="female" />
                            <label class="form-check-label" for="female">女</label>
                        </div>
                        <span asp-validation-for="Input.Seibetsu" class="text-danger small d-block"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-md-3 col-form-label fw-bold small">部署<span class="text-danger fw-bold">*</span><span class="text-primary fw-bold">*</span></label>
                    <div class="col-md-5">
                        <div class="input-group">
                            <input asp-for="Input.BusyoName" class="form-control form-control-sm bg-light" readonly  />
                            <input type="hidden" asp-for="Input.BusyoId" id="Input_BusyoId" />
                            <input type="hidden" asp-for="Input.BusyoCode" id="Input_BusyoCode" />
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btnSearchBusyo" title="検索">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.BusyoName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.GyoumuTypeId" class="col-md-3 col-form-label fw-bold small">業務種別</label>
                    <div class="col-md-4">
                        <select asp-for="Input.GyoumuTypeId" asp-items="Model.GyoumuTypeOptions" class="form-select form-select-sm"></select>
                    </div>
                </div>

                <div class="row mb-3 align-items-center position-relative">
                    <label asp-for="Input.StartDate" class="col-md-3 col-form-label fw-bold small">
                        適用開始日<span class="text-danger fw-bold">*</span>
                    </label>
                    <div class="col-md-3 position-relative">
                        <input asp-for="Input.StartDate" type="date" class="form-control form-control-sm" />
                        <span asp-validation-for="Input.StartDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-md-3 col-form-label fw-bold small">有効開始日</label>
                    <div class="col-md-3">
                        <label style="font-family:'Yu Gothic','游ゴシック',sans-serif; font-size:14px;">
                            @Model.Input.StartYmd.ToString("yyyy-MM-dd")
                        </label>
                        <input type="hidden" asp-for="Input.StartYmd" />
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-md-3 col-form-label fw-bold small">有効終了日</label>
                    <div class="col-md-3">
                        <label style="font-family:'Yu Gothic','游ゴシック',sans-serif; font-size:14px;">
                            @Model.Input.EndYmd.ToString("yyyy-MM-dd")
                        </label>
                        <input type="hidden" asp-for="Input.EndYmd" />
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.Kyusyoku" class="col-md-3 col-form-label fw-bold small">
                        級職<span class="text-danger fw-bold">*</span><span class="text-primary fw-bold">*</span>
                    </label>
                    <div class="col-md-3">
                        <input asp-for="Input.Kyusyoku" type="text" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.SyucyoSyokui" class="col-md-3 col-form-label fw-bold small">出張職位<span class="text-danger fw-bold">*</span><span class="text-primary fw-bold">*</span></label>
                    <div class="col-md-4">
                        <select asp-for="Input.SyucyoSyokui" class="form-select form-select-sm" id="Input_SyucyoSyokui">
                            <option value="">未選択</option>
                            <option value="1">2級</option>
                            <!-- 今後 enum 実装予定。暫定で 1 を 2級扱い -->
                        </select>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.KingsSyozoku" class="col-md-3 col-form-label fw-bold small">KINGS所属<span class="text-danger fw-bold">*</span></label>
                    <div class="col-md-3">
                        <input asp-for="Input.KingsSyozoku" class="form-control form-control-sm" />
                        <span asp-validation-for="Input.KingsSyozoku" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.KintaiZokuseiId" class="col-md-3 col-form-label fw-bold small">勤怠属性<span class="text-danger fw-bold">*</span><span class="text-primary fw-bold">*</span></label>
                    <div class="col-md-4">
                        <select asp-for="Input.KintaiZokuseiId" asp-items="Model.KintaiZokuseiOptions" class="form-select form-select-sm"></select>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.IsGenkaRendou" class="col-md-3 col-form-label fw-bold small mb-0">
                        原価連動フラグ<span class="text-primary fw-bold">*</span>
                    </label>
                    <div class="col-md-4">
                        <div class="form-check form-switch">
                            <input asp-for="Input.IsGenkaRendou" type="checkbox" class="form-check-input" />
                        </div>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.KaisyaCode" class="col-md-3 col-form-label fw-bold small">利用会社<span class="text-danger fw-bold">*</span><span class="text-primary fw-bold">*</span></label>
                    <div class="col-md-4">
                        <select asp-for="Input.KaisyaCode" asp-items="Model.CompanyOptions" class="form-select form-select-sm"></select>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.EMail" class="col-md-3 col-form-label fw-bold small">Email</label>
                    <div class="col-md-4">
                        <input asp-for="Input.EMail" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.KeitaiMail" class="col-md-3 col-form-label fw-bold small">携帯Mail</label>
                    <div class="col-md-4">
                        <input asp-for="Input.KeitaiMail" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.PhoneNumber" class="col-md-3 col-form-label fw-bold small">携帯番号</label>
                    <div class="col-md-3">
                        <input asp-for="Input.PhoneNumber" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.Retired" class="col-md-3 col-form-label fw-bold small mb-0">退職フラグ</label>
                    <div class="col-md-4">
                        <div class="form-check form-switch">
                            <input asp-for="Input.Retired" type="checkbox" class="form-check-input" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 社員関連情報 -->
        <div class="border border-dark rounded mb-4">
            <div class="bg-primary text-white px-3 py-2 fw-bold fs-5 rounded-top">
                社員関連情報
            </div>
            <div class="px-4 py-3 border-top border-dark rounded-bottom">
                <div class="d-flex align-items-center mb-3">
                    <!-- 左側：有給ラベル -->
                    <div class="fw-bold small me-3" style="width: 80px;">有給</div>

                    <!-- 右側：3項目を横並び（幅固定） -->
                    <div class="d-flex flex-grow-1 gap-2 align-items-end">
                        <div style="width: 100px;">
                            <label class="form-label small">有給割当日数</label>
                            <input asp-for="Input.Wariate" class="form-control form-control-sm" style="width: 100%;" />
                        </div>
                        <div style="width: 100px;">
                            <label class="form-label small">有給繰越日数</label>
                            <input asp-for="Input.Kurikoshi" class="form-control form-control-sm no-border" />
                        </div>
                        <div style="width: 100px;">
                            <label class="form-label small">有給消化日数</label>
                            <input asp-for="Input.Syouka" class="form-control form-control-sm no-border" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 権限（ロール＋チェックボックス） -->
        <div class="border border-dark rounded mb-4">
            <div class="bg-primary text-white px-3 py-2 fw-bold fs-5 rounded-top">
                権限
            </div>
            <div class="px-4 py-3 border-top border-dark rounded-bottom">

                <!-- ロール -->
                <div class="row mb-3 align-items-center">
                    <label asp-for="Input.UserRoleId" class="col-md-3 col-form-label fw-bold small">
                        ロール<span class="text-danger fw-bold">*</span>
                    </label>
                    <div class="col-md-4">
                        <select asp-for="Input.UserRoleId" asp-items="Model.RoleOptions"
                                class="form-select form-select-sm" id="Input_UserRoleId">
                        </select>
                    </div>
                </div>

                <!-- 権限 -->
                <div class="row mb-3 align-items-start">
                    <label class="col-md-3 col-form-label fw-bold small">権限</label>
                    <div class="col-md-9">
                        <div class="row">
                            <!-- 左列 -->
                            <div class="col-md-6">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm1Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm1Checked">労働状況報告</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm2Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm2Checked">勤務日報未確定チェック</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm3Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm3Checked">出退勤一覧画面の部署選択</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm4Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm4Checked">出退勤一覧の打刻位置確認</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm5Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm5Checked">PCログ出力</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm6Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm6Checked">管理機能利用（人財向け）</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm7Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm7Checked">指示承認者</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm8Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm8Checked">計画休暇承認</label>
                                </div>
                            </div>

                            <!-- 右列 -->
                            <div class="col-md-6">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm9Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm9Checked">労働最終警告メール送信対象者</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm10Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm10Checked">勤務日報未確定者への通知</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm11Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm11Checked">出退勤一覧の打刻時間修正</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm12Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm12Checked">部門プロセス設定</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm13Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm13Checked">勤怠データ出力</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm14Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm14Checked">管理機能利用（その他）</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" asp-for="Input.Perm15Checked" />
                                    <label class="form-check-label" asp-for="Input.Perm15Checked">指示最終承認者</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>


        <!-- 登録ボタン -->
        <div class="fixed-bottom bg-white border-top border-dark px-3 py-2 text-end">
            <button type="button" class="btn btn-primary" id="registerBtn"><i class="fa-solid fa-check text-white"></i>登録</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(function () {
            // 部署検索
            $('#btnSearchBusyo').on('click', function () {
                const modalId = 'BusyoSearchModal';
                const url = '@Url.Page("/Maintenance/Busyo/Search")';
                const title = '部署検索';
                showInputModal(modalId, url, null, title, null, 800, 480, 'var(--iframe-header-color)');
            });



            // ロール選択時の上書き確認 → 既定権限反映
            $('#Input_UserRoleId').on('change', function () {
            const roleId = $(this).val();
            if (!roleId) return;

            commonConfirm('権限のチェックをロールの初期権限で上書きします。よろしいですか？', null, function () {
                $.get('@Url.Page("./SyainInsert", "RoleDefaults")', { roleId: roleId }, function (defaults) {
                    $('input[type=checkbox][name^="Input.Perm"]').prop('checked', false);

                    if (defaults.isLaborStatusReport) $('#Input_Perm1Checked').prop('checked', true);
                    if (defaults.isCheckPendingReports) $('#Input_Perm2Checked').prop('checked', true);
                    if (defaults.isSelectDepartment) $('#Input_Perm3Checked').prop('checked', true);
                    if (defaults.isCheckStampPosition) $('#Input_Perm4Checked').prop('checked', true);
                    if (defaults.isPcLogOutput) $('#Input_Perm5Checked').prop('checked', true);
                    if (defaults.isManagementFunctionsHumanResources) $('#Input_Perm6Checked').prop('checked', true);
                    if (defaults.isInstructionApprover) $('#Input_Perm7Checked').prop('checked', true);
                    if (defaults.isPlannedLeaveApproval) $('#Input_Perm8Checked').prop('checked', true);
                    if (defaults.isFinalLaborWarningEmailRecipients) $('#Input_Perm9Checked').prop('checked', true);
                    if (defaults.isNotificationReportUnconfirmed) $('#Input_Perm10Checked').prop('checked', true);
                    if (defaults.isCorrectingTimeStamps) $('#Input_Perm11Checked').prop('checked', true);
                    if (defaults.isDepartmentProcessSettings) $('#Input_Perm12Checked').prop('checked', true);
                    if (defaults.isAttendanceDataOutput) $('#Input_Perm13Checked').prop('checked', true);
                    if (defaults.isManagementFunctionsOther) $('#Input_Perm14Checked').prop('checked', true);
                    if (defaults.isFinalInstructionApprover) $('#Input_Perm15Checked').prop('checked', true);
                });
            });
        });


            // 写真設定（ダイアログ起動等は後で実装）
            $('#btnSetPhoto').on('click', function () {
                // TODO: 写真アップロード/選択モーダル
            });

            // 登録
            $('#registerBtn').on('click', function () {
                register('登録', 'Register');
            });
        });

        function openBusyoSearch() {
            const modalId = 'BusyoSearchModal';
            const url = '@Url.Page("/BusyoSentaku/Index", new { mode = "single" })';
            const title = '部署選択';
            showInputModal(modalId, url, null, title, null, 800, 480, 'var(--iframe-header-color)');
        }

        document.getElementById("btnSearchBusyo").addEventListener("click", openBusyoSearch);


        // 部署選択モーダルから返ってくる
                window.receiveBusyoSelection = function (payload) {
            if (!payload || payload.length === 0) return;

            const busyo = payload[0];

            document.getElementById("Input_BusyoName").value = busyo.name;
            document.getElementById("Input_BusyoId").value = busyo.id;
            document.getElementById("Input_BusyoCode").value = busyo.code;
        };


        /** 登録 */
        function register(actionName, handler) {
            commonConfirm(actionName + 'します。よろしいですか？', null, function () {
                sendRegisterAjax(toUrl(handler), $('form').serializeArray(), function (data) {
                    registerSuccessSwal(actionName + 'しました', null, function () {
                        closeCurrentIziModal();
                    });
                });
            });
        }
    </script>
}
