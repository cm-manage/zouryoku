@model PartialPageModel

<article class="row row-cols-1 row-cols-lg-2 g-3">
    @foreach (var item in Model.Juchus)
    {
        <div class="col">
            @* 受注情報カード *@
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        @* 受注情報選択 *@
                        @* カード選択時に親画面に送信するデータをdata属性に保持 *@
                        <form class="col app-clickable"
                              data-js="juchuSelect"
                              data-juchu-id="@item.JuchuId"
                              data-project-no="@item.ProjectNo"
                              data-juchuu-no="@item.JuchuuNo"
                              data-juchuu-gyo-no="@item.JuchuuGyoNo"
                              data-bukken="@item.Bukken">
                            @Html.AntiForgeryToken()

                            @* 受注番号(プロジェクト番号-受注番号-受注行番号) *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.JuchuuNoForDisplay)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.JuchuuNoForDisplay)</span>
                            </div>
                            @* 非表示で個別に持つ(プロジェクト番号, 受注番号, 受注行番号) *@
                            <input type="hidden" value="@item.ProjectNo" data-project-no="@item.ProjectNo" />
                            <input type="hidden" value="@item.JuchuuNo" data-juchuu-no="@item.JuchuuNo" />
                            <input type="hidden" value="@item.JuchuuGyoNo" data-juchuu-gyo-no="@item.JuchuuGyoNo" />
                            @* 受注先顧客 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.JuchuuKokyakuName)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.JuchuuKokyakuName)</span>
                            </div>
                            @* 契約先顧客 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.KeiyakuKokyakuName)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.KeiyakuKokyakuName)</span>
                            </div>
                            @* 受注件名 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.Bukken)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.Bukken)</span>
                            </div>
                            @* 商品名 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.ShouhinName)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.ShouhinName)</span>
                            </div>
                            @* 受注金額 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.JucKin)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.JucKin)</span>
                            </div>
                            @* 着工日 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.ChaYmd)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.ChaYmd)</span>
                            </div>
                            @* 受注日 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.JucYmd)</span>
                                <span class="col text-nowrap">@Html.DisplayFor(model => item.JucYmd)</span>
                            </div>
                            @* 受注取消 *@
                            <div class="row">
                                <span class="text-secondary text-nowrap col-3">@Html.DisplayNameFor(model => item.Deleted)</span>
                                <span class="col text-nowrap deleted-mark">@Html.DisplayFor(model => item.Deleted)</span>
                            </div>
                            <input type="hidden" name="juchuId" value="@item.JuchuId" />
                        </form>
                        @* 受注情報画面のモーダル表示 *@
                        <div class="col-2 d-flex flex-row align-items-center">
                            <div class="text-primary fs-4" role="button" data-js="juchuShowInfo" data-juchu-id="@item.JuchuId">
                                <i class="fa-solid fa-chevron-right"></i>
                            </div>
                        </div>
                    </div>
                    @if (Model.IsReferHistory)
                    {
                        @* 顧客会社参照履歴削除ボタン *@
                        <form class="d-flex justify-content-end">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="juchuId" value="@item.JuchuId" />
                            <input type="hidden" name="version" value="@item.Version" />
                            <button class="app-btn__base btn btn-outline-danger" type="button" data-js="historyDelete">
                                <i class="fa-solid fa-trash"></i>
                                履歴削除
                            </button>
                        </form>
                    }
                </div>
            </div>

        </div>
    }
</article>