@model Zouryoku.Pages.Example.ModalSearchModel.ViewModel

<form>
    <div class="d-flex flex-column gap-1 mt-2">
        <div class="d-flex align-items-center gap-1">
            @* 名前 *@
            <label asp-for="Name" class="label-local">@Html.DisplayNameFor(m => m.Name)</label>
            <div>
                <span asp-validation-for="Name" class="text-danger"></span>
                <input type="text" asp-for="Name" class="form-control input-local" />
            </div>
        </div>
        <div class="d-flex align-items-center gap-1">
            @* 住所 *@
            <label asp-for="Address" class="label-local">@Html.DisplayNameFor(m => m.Address)</label>
            <div>
                <span asp-validation-for="Address" class="text-danger"></span>
                <input type="text" asp-for="Address" class="form-control input-local" />
            </div>
        </div>
        <div class="d-flex align-items-center gap-1">
            @* 電話番号 *@
            <label asp-for="Tel" class="label-local">@Html.DisplayNameFor(m => m.Tel)</label>
            <div>
                <span asp-validation-for="Tel" class="text-danger"></span>
                <input type="text" asp-for="Tel" class="form-control input-local" />
            </div>
        </div>
        <div class="d-flex align-items-center">
            @* 検索ボタン *@
            <button type="button" id="search-btn" class="btn btn-primary text-nowrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                検索
            </button>
        </div>
    </div>
</form>



@* CSS *********************************************************************************@
<style>
    .label-local {
        width: 4rem;
    }

    .input-local {
        width: 10rem;
    }
</style>
