@page
@model Zouryoku.Pages.Maintenance.PhotoList.IndexModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "顔写真一覧";
}

<!-- iziModal CSS -->
<link type="text/css" rel="stylesheet" href="~/assets/modules/iziModal/css/iziModal.css" asp-append-version="true" />

<style>
    .busyo-section {
        margin-bottom: 40px;
    }

    .busyo-title {
        font-weight: bold;
        font-size: 18px;
        padding: 15px;
        background-color: #f5f5f5;
        border-bottom: 2px solid #ddd;
        margin-bottom: 20px;
        border-radius: 4px;
    }

    .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, 100px);
        gap: 20px;
        margin-bottom: 20px;
    }

    .photo-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .photo-container {
        width: 100px;
        height: 120px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f5f5f5;
        border: 1px solid #ddd;
        border-radius: 4px;
        overflow: hidden;
    }

        .photo-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .photo-container a {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .photo-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f5f5f5;
        color: #999;
        font-size: 12px;
    }

    .syain-name {
        font-size: 14px;
        word-break: break-word;
        max-width: 120px;
        line-height: 1.4;
        color: #333;
    }
</style>

<partial name="_ZouryokuHeader" model="Model" />
<div class="app-screen--search">
    <div class="app-area__search-results">
        @* 各部署をループ *@
        @foreach (var busyoGroup in Model.BusyoPhotoGroups)
        {
            <div class="busyo-section">
                <div class="busyo-title">@busyoGroup.BusyoName</div>

                @* 後端で分割済みのPhotoChunksをループ 1行に表示する写真数のグループ*@
                @foreach (var chunk in busyoGroup.PhotoChunks)
                {
                    <div class="photo-grid">
                        @foreach (var photo in chunk)
                        {
                            <div class="photo-item">
                                <div class="photo-container">
                                    <a href="javascript:void(0);"
                                        class="js-open-syain-detail"
                                        data-syain-id="@photo.SyainBaseId"
                                        style="cursor: pointer;">
                                        @if (photo.HasPhoto)
                                        {
                                            <img src="/maintenance/photolist/downloadthumbnail?baseid=@photo.SyainBaseId&t=@photo.UploadTime.Ticks"
                                                alt="@photo.SyainName"
                                                loading="lazy" />
                                        }
                                        else
                                        {
                                            <img src="~/img/noimage.jpg" alt="@photo.SyainName" />
                                        }
                                    </a>
                                </div>
                                <div class="syain-name">@photo.SyainName</div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@section scripts {
    <script src="~/assets/modules/iziModal/js/iziModal.min.js" asp-append-version="true"></script>
    <!--iziModalUtil JavaScript -->
    <script src="~/js/iziModalUtil.js" asp-append-version="true"></script>
    <script>
        // 社員詳細モーダルを開く（PcLogs の openPcLogDetails を参考）
        function openSyainDetails(id) {
            const modalId = 'syainDetailsModal';
            const url = '@Url.Page("./Details")';
            const title = '社員詳細';

            // 閉じた後の処理は特に不要なので空のコールバック
            showInputModal(
                modalId,
                url,
                id,
                title,
                function () { },
                800,
                800,
                'var(--iframe-header-color)'
            );
        }

        $(function () {
            // サムネイルクリックで社員詳細をポップアップ表示
            $(document).on('click', '.js-open-syain-detail', function () {
                const syainId = $(this).data('syain-id');
                if (!syainId) {
                    return;
                }
                openSyainDetails(syainId);
            });
        });
    </script>
}