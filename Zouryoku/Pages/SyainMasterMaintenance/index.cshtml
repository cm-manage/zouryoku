@page
@model Zouryoku.Pages.SyainMastaMaintenance.SearchModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "社員検索";
}
<link type="text/css" rel="stylesheet" href="~/assets/modules/iziModal/css/iziModal.css" asp-append-version="true" />
<partial name="_ZouryokuHeader" model="Model" />

<form method="get" id="syain-search-form" onsubmit="$('#syain-search-btn').trigger('click'); return false;">
    <div class="row g-3">
        <!-- 左カラム -->
        <div class="col-md-6">
            <div class="row mb-2">
                <label asp-for="Condition.SyainNo" class="col-2 col-form-label fw-bold text-nowrap">社員番号</label>
                <div class="col">
                    <input asp-for="Condition.SyainNo" class="form-control" placeholder="社員番号を入力" />
                </div>
            </div>

            <div class="row mb-3 align-items-center">
                <label asp-for="Condition.BusyoName" class="col-md-2 col-form-label fw-bold small">部署</label>
                <div class="col-md-6">
                    <div class="input-group">
                        <!-- 表示用：部署名 -->
                        <input asp-for="Condition.BusyoName"
                               class="form-control form-control-sm bg-light"
                               readonly />
                        <!-- 検索ボタンのみ -->
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnSearchBusyo" title="検索">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </div>
                </div>
            </div>


            <div class="row mb-2">
                <label asp-for="Condition.Grade" class="col-2 col-form-label fw-bold text-nowrap">級職</label>
                <div class="col">
                    <input asp-for="Condition.Grade" class="form-control" placeholder="級職を入力" />
                </div>
            </div>

            <div class="row mb-2">
                <label asp-for="Condition.UserRoleId" class="col-2 col-form-label fw-bold text-nowrap">ロール</label>
                <div class="col">
                    <select asp-for="Condition.UserRoleId" asp-items="Model.UserRoleOptions" class="form-select">
                        <option value="">-- 未選択 --</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- 右カラム -->
        <div class="col-md-6">
            <div class="row mb-2">
                <label asp-for="Condition.SyainName" class="col-2 col-form-label fw-bold text-nowrap">社員名</label>
                <div class="col">
                    <input asp-for="Condition.SyainName" class="form-control" placeholder="社員名を入力" />
                </div>
            </div>

            <div class="row mb-2">
                <label class="col-2 col-form-label fw-bold text-nowrap">退職者を含む</label>
                <div class="col d-flex align-items-center">
                    <div class="form-check form-switch m-0">
                        <input asp-for="Condition.IncludeRetired" class="form-check-input" type="checkbox" />
                    </div>
                </div>
            </div>

            <div class="row mb-2">
                <label asp-for="Condition.KintaiZokuseiId" class="col-2 col-form-label fw-bold text-nowrap">勤怠属性</label>
                <div class="col">
                    <select asp-for="Condition.KintaiZokuseiId" asp-items="Model.KintaiZokuseiOptions" class="form-select">
                        <option value="">-- 未選択 --</option>
                    </select>

                </div>
            </div>

            <div class="row mb-2">
                <label asp-for="Condition.Kengen" class="col-2 col-form-label fw-bold text-nowrap">社員権限</label>
                <div class="col">
                    <select asp-for="Condition.Kengen" class="form-select" asp-items="Model.KengenOptions">
                        <option value="">-- 未選択 --</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column align-items-end mt-3">
        <button type="submit" class="btn btn-primary btn-sm mb-2 btn-fixed"><i class="fa-solid fa-magnifying-glass"></i>検索</button>
        <div>
            <button type="button" class="btn btn-success btn-sm me-2 btn-fixed" onclick="openInsert(null)">
                <i class="fa fa-plus text-white"></i>新規作成
            </button>

            <button type="button" class="btn btn-secondary btn-sm btn-fixed" onclick="openSyainSort()">
                <i class="fa-solid fa-arrow-up-arrow-down text-white"></i>順序変更
            </button>
        </div>
    </div>

    <style>
        .btn-fixed {
            min-width: 85px; 
            text-align: center; 
        }
    </style>


</form>


<div id="syain-search-results">
    <table class="table app-table__base table-bordered table-striped table-hover text-nowrap">
        <thead class="table-primary text-center align-middle">
            <tr>
                <th style="width: 10%">社員番号</th>
                <th style="width: 20%">社員名</th>
                <th style="width: 30%">部署</th>
                <th style="width: 7%">級職</th>
                <th style="width: 16%">勤怠属性</th>
                <th style="width: 7%">ロール</th>
                <th style="width: 7%">退職</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var syain in Model.Results)
            {
                <tr>
                    <td class="text-center align-middle">@syain.SyainNo</td>
                    <td class="align-middle">
                        <a href="javascript:void(0);" class="text-decoration-none fw-bold text-primary"
                           onclick="openInsert(@syain.Id);">
                            @syain.Name
                        </a>
                    </td>
                    <td>@syain.BusyoName</td>
                    <td class="text-center align-middle">@syain.Grade</td>
                    <td class="text-center align-middle">@syain.KintaiZokuseiName</td>
                    <td class="text-center align-middle">@syain.UserRoleName</td>
                    <td class="text-center align-middle">@syain.RetiredDisplay</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/assets/modules/iziModal/js/iziModal.min.js" asp-append-version="true"></script>
    <script src="~/js/iziModalUtil.js" asp-append-version="true"></script>

    <script>
        let currentBusyoTarget = null;

        function openInsert(id) {
            const modalId = 'InsertModal';
            const url = '@Url.Page("/SyainMastaTouroku/Index")';
            const title = id ? '社員マスタ登録' : '社員マスタ登録';
            showInputModal(
                modalId,
                url,
                id,
                title,
                function () { location.reload(); },
                800,
                480,
                'var(--iframe-header-color)'
            );
        }

        function openSyainSort() {
            const modalId = 'SortModal';
            const url = '@Url.Page("/SyainSort/Index")';
            const title = '社員順序並び替え';
            showInputModal(
                modalId,
                url,
                null,
                title,
                function () { location.reload(); },
                800,
                480,
                'var(--iframe-header-color)'
            );
        }

        function openBusyoSearch() {
            const modalId = 'BusyoSearchModal';
            const url = '@Url.Page("/BusyoSentaku/Index", new { mode = "single" })';
            const title = '部署選択';
            showInputModal(
                modalId,
                url,
                null,
                title,
                null,
                800,
                480,
                'var(--iframe-header-color)'
            );
        }

        const btnSearchBusyo = document.getElementById("btnSearchBusyo");
        if (btnSearchBusyo) {
            btnSearchBusyo.addEventListener("click", function () {
                openBusyoSearch();
            });
        }

        window.addEventListener("message", function (event) {

            const data = event.data;
            if (!data) return;

            if (data.type === "busyoSelected") {
                const busyo = data.payload;
                if (!busyo) return;

                const nameInput = document.querySelector('[name="Condition.BusyoName"]');
                if (nameInput) {
                    nameInput.value = busyo.name ?? busyo.Name ?? "";
                    nameInput.dispatchEvent(new Event('input', { bubbles: true }));
                }

                const idInput = document.querySelector('[name="Condition.BusyoId"]');
                if (idInput) {
                    idInput.value = busyo.id ?? busyo.Id ?? "";
                } else {
                    const form = document.querySelector('form[asp-page-handler="Search"]') || document.querySelector('form');
                    if (form) {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'Condition.BusyoId';
                        hidden.value = busyo.id ?? busyo.Id ?? "";
                        form.appendChild(hidden);
                    }
                }
            }
        });

        $(function () {

            const $searchForm = $('#syain-search-form');
            const $partialPage = $('#syain-search-results');

            // 社員検索をサーバに投げる
            function searchSyain(form) {
                return new Promise(resolve => {
                    sendGetAjax(
                        toUrl('Search'),   // ← OnGetSearchAsync を叩く
                        form.serializeArray(),
                        data => resolve(data),
                        false
                    );
                });
            }

            // 検索ボタンクリック
            $('#syain-search-btn').on('click', async function () {
                const html = await searchSyain($searchForm);
                $partialPage.html(html);
            });

            // Enter キーで検索
            $searchForm.on('keypress', function (e) {
                if (e.which === 13) {
                    $('#syain-search-btn').click();
                    return false;
                }
            });

            // 結果行クリックで編集モーダル
            $partialPage.on('click', '.syain-link', function (e) {
                e.preventDefault();
                const id = $(this).data('id');
                openInsert(id);
            });

        });
    </script>
}



