@page
@model Zouryoku.Pages.Page404Model
@{
    Layout = "_Layout_NoSession";
    ViewData["Title"] = "ページが見つかりませんでした";
}
<!-- page css -->
<link href="/css/error-pages.css" rel="stylesheet" asp-append-version="true">
<div class="center-page-area">
    <div class="box m">
        <div class="contents">
            <section id="wrapper" class="error-page">
                <div class="error-box">
                    <div class="error-body text-center">
                        <h1>404</h1>
                        <h3 class="text-uppercase" style="margin-bottom:20px">ページが見つかりませんでした</h3>
                        <div class="form-group  btn_area text_center">
                            <button class="btn btn-blue kng-style" type="button" onclick="location.href='@Url.Content("~/Logins/Index")'">ログインに戻る</button>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
