@model Zouryoku.Pages.Example.ModalRegisterModel.ViewModel

<form method="post">
    <div class="d-flex flex-column gap-1 mt-1">
        @for (int i = 0; i < Model.Cards.Count; i++)
        {
            @* カード *@
            <input type="hidden" asp-for="Cards[i].Name" value="@Model.Cards[i].Name" />
            <section class="card rounded-3">
                <div class="card-body d-flex w-100 p-2">
                    <div class="w-100">
                        @* サンプル用にスペース確保 *@
                        <div class="py-5"></div>
                    </div>
                    <div class="card-side">
                        @* 削除ボタン *@
                        <button type="button" data-index="@i" class="btn btn-outline-danger delete-btn">
                            <i class="fa-solid fa-trash"></i>
                            削除
                        </button>
                    </div>
                </div>
            </section>
        }

        <div class="text-end">
            @* 追加ボタン *@
            <button type="button" id="insert-btn" class="btn btn-outline-success">
                <i class="fa-solid fa-plus"></i>
                追加
            </button>
        </div>
    </div>
</form>

@* フッター用にスペースを確保 *@
<div class="py-5 my-5"></div>

<div class="fixed-bottom bg-body">
    <hr />
    <div class="text-end p-2">
        @* 登録ボタン *@
        <button type="button" id="register-btn" class="btn btn-primary">
            <i class="fa-solid fa-check"></i>
            登録
        </button>
    </div>
</div>



@* CSS *********************************************************************************@
<style>
    .card-side {
        width: 6rem;
        max-width: 6rem;
        text-align: right;
    }
</style>
