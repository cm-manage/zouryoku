<script>
    //
    //  画面リンクセクション用スクリプト
    //  scriptタグごと削除すること！！
    //
    (() => {
      "use strict";

      // クエリを最低限正規化してURLに付与する
      function buildUrl(baseUrl, rawQuery) {
        const url = (baseUrl ?? "").trim();
        if (!url) return null;

        const query = (rawQuery ?? "").trim();
        if (!query) return url;

        // 先頭の ?, &, 空白などを除去（ユーザー入力揺れ対策）
        const normalized = query.replace(/^[?&\s]+/, "");
        if (!normalized) return url;

        // baseUrlに既に?がある場合は & で連結
        const joiner = url.includes("?") ? "&" : "?";
        return url + joiner + normalized;
      }

      // テーブル全体でイベント委譲（25行でも軽い）
      document.addEventListener("click", (e) => {
        const btn = e.target.closest(".js-move");
        if (!btn) return;

        const row = btn.closest("tr");
        if (!row) return;

        const target = row.dataset.target; // data-target
        const paramInput = row.querySelector(".js-param");
        const paramValue = paramInput ? paramInput.value : "";

        const finalUrl = buildUrl(target, paramValue);

        if (!finalUrl) {
          // 遷移先未設定など、開発時に気づけるようにする
          console.warn("遷移先URLが未設定です。該当行の data-target を確認してください。", row);
          return;
        }

        // 実際に遷移
        window.location.href = finalUrl;
      });
    })();
</script>
<style>
